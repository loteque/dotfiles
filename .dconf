[org/gnome/evolution-data-server/calendar]
reminders-past=['4a30b5ae58c780d73fcebabc319b628b8afc987e\nbdf1f6f794d756d1394eb2cbc19eb3010a157173\t20240608T190000\n1717897800\n1717898400\n1717909200\nBEGIN:VEVENT\r\nDTSTART;TZID=America/Los_Angeles:20240608T190000\r\nDTEND;TZID=America/Los_Angeles:20240608T220000\r\nDTSTAMP:20240528T041812Z\r\nUID:5kndlguhtn07s61fmpe56m502v@google.com\r\nCREATED:20240528T041812Z\r\nDESCRIPTION:Join community friends and hear June’s Creative Theme \r\n reveal for the "Resource Management" Summer Slow Jam!\\n\\nIt’s time to \r\n get resourceful for the first SSJ of the year! \\n- Chat with others about \r\n forming teams - PIGSquad organizers can help introduce you after the \r\n opening if needed\\n- Hear the Creative Theme and start brainstorming game \r\n ideas\\n- Learn about processes that can help you make a resource \r\n management game\\n- Start making a game on June 8th\\, then finish it and \r\n share on the 28th!\\n\\nSIGN UP FOR THE JAM at https:\r\n //itch.io/jam/ssjresourcemanagement\\n\\nWe will also be hosting a stream \r\n for the Kickoff on http://twitch.tv/pigsquad\\n\\nLearn more about Summer \r\n Slow Jams at http://pigsquad.com/summerslowjams\\n\\nWearing a mask at all \r\n times (except eating and drinking) is required to attend the physical \r\n portion of this event.\r\nLAST-MODIFIED:20240528T041812Z\r\nLOCATION:Wacom Experience Center 1455 NW Irving St. Portland & at \r\n twitch.tv/pigsquad\r\nSEQUENCE:0\r\nSTATUS:CONFIRMED\r\nSUMMARY:Summer Slow Jams: "Resource Management" Opening Event\r\nTRANSP:OPAQUE\r\nX-EVOLUTION-CALDAV-ETAG:63852553092\r\nBEGIN:VALARM\r\nACTION:DISPLAY\r\nDESCRIPTION:This is an event reminder\r\nTRIGGER:-PT10M\r\nX-EVOLUTION-ALARM-UID:bdf1f6f794d756d1394eb2cbc19eb3010a157173\r\nEND:VALARM\r\nEND:VEVENT\r\n']

